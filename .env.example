# ── App ─────────────────────────────────────────────
# Public URL of the app (no trailing slash). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# ── Database (Railway Postgres) ─────────────────────
# Railway: add a "Postgres" plugin to your project, then reference its
# ${{Postgres.DATABASE_URL}} in this service's variables.
DATABASE_URL=postgresql://user:password@localhost:5432/detaildesk

# ── Sessions ────────────────────────────────────────
# Random 32+ char secret used to sign the auth session cookie (HS256).
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# ── Stripe (PLATFORM account keys — not the pros' keys) ──
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ID of the "DetailDesk Pro" 29€/month recurring price (platform account)
STRIPE_PRICE_ID=
# Webhook endpoint secret for /api/webhooks/stripe (account events)
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint secret for /api/webhooks/stripe-connect (Connect events)
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── Resend ──────────────────────────────────────────
RESEND_API_KEY=
# e.g. "DetailDesk <bookings@yourdomain.com>" (verified domain in prod)
RESEND_FROM_EMAIL=DetailDesk <onboarding@resend.dev>

# ── ClickSend (SMS reminders — platform account) ────
# Pros get 150 SMS/month included, overage billed 1€ per 10 SMS.
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=

# ── Platform admin ──────────────────────────────────
# Comma-separated emails auto-granted platform_admin on signup
PLATFORM_ADMIN_EMAILS=

# ── Monitoring (optional) ───────────────────────────
# Sentry project DSN — leave empty to disable error monitoring
SENTRY_DSN=

# ── Cron ────────────────────────────────────────────
# Shared secret for /api/cron/reminders (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
